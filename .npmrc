# pnpm build-script allowlist lives in package.json -> pnpm.onlyBuiltDependencies.
# TS 7 native-preview fails to resolve packages reliably from pnpm's isolated linker.
# Keep the workspace on a hoisted layout so pnpm check/build stay stable.
node-linker=hoisted

# --- supply-chain hardening: release cooldown (TeamPCP / npm install-time malware) ---
# Refuse to install any package version published less than 24h (1440 min) ago,
# so a freshly-published malicious version has time to be detected and yanked
# before it reaches this machine. pnpm 11 makes this a default; older pnpm
# ignores the unknown key harmlessly. Adjust the window as you like.
minimum-release-age=1440
