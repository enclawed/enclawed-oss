# Secretary demo environment.
#
# Copy to .env (the installer writes this for you at
# ~/.enclawed/enclawed-apps/secretary/.env) and `source` it before running
# `enclawed demo run secretary`.

# ─── REQUIRED ────────────────────────────────────────────────────────

# The principal's primary email address. The secretary replies on their
# behalf; the EOD summary is delivered to this inbox; self-sent messages
# are recognized via this address and never auto-replied to.
ENCLAWED_SECRETARY_PRINCIPAL_EMAIL="you@example.com"

# Google Workspace MCP OAuth — pick ONE of the two paths.
#
#   Path A (recommended for development): pre-acquired bearer.
#   Run `gcloud auth print-access-token` and paste the result here.
#   Tokens expire in ~55 minutes; you'll need to refresh manually
#   before each run.
# ENCLAWED_GOOGLE_OAUTH_TOKEN="ya29.…"

#   Path B (recommended for unattended runs): refresh token.
#   The installer walks you through creating an OAuth client in
#   Google Cloud Console and running the consent flow; paste the
#   resulting credentials here. The bridge then refreshes
#   automatically.
ENCLAWED_GOOGLE_OAUTH_CLIENT_ID="…apps.googleusercontent.com"
ENCLAWED_GOOGLE_OAUTH_CLIENT_SECRET="…"
ENCLAWED_GOOGLE_OAUTH_REFRESH_TOKEN="1//…"

# ─── OPTIONAL ────────────────────────────────────────────────────────

# Ollama model. Default qwen2.5:7b-instruct (good balance of quality
# and footprint). On a 4 GB RAM box use llama3.2:3b. On a 24 GB+ box
# qwen2.5:14b-instruct gives noticeably better drafts.
ENCLAWED_SECRETARY_OLLAMA_MODEL="qwen2.5:7b-instruct"

# Ollama API base. Default 127.0.0.1:11434.
# OLLAMA_HOST="127.0.0.1:11434"

# Audit-log path override. Default
#   ~/.enclawed/enclawed-apps/secretary/audit.jsonl
# ENCLAWED_AUDIT_PATH="/var/log/enclawed/secretary-audit.jsonl"

# Classification scheme. Default "enclawed-default" (6 levels). The
# demo uses level=1 (INTERNAL). For sector-specific deployments swap
# in "healthcare-hipaa", "financial-services", "us-government", or
# "generic-3-tier".
# ENCLAWED_CLASSIFICATION_SCHEME="enclawed-default"
