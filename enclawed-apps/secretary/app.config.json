{
  "id": "secretary",
  "name": "AI Secretary",
  "package": "enclawed-secretary-app",
  "provider": {
    "type": "imap-caldav-carddav",
    "services": ["mail", "calendar", "contacts"],
    "appPasswordUrl": "https://myaccount.google.com/apppasswords",
    "imap": {
      "host": "imap.gmail.com",
      "port": 993,
      "secure": true
    },
    "smtp": {
      "host": "smtp.gmail.com",
      "port": 465,
      "secure": true
    },
    "caldav": {
      "serverUrl": "https://apidata.googleusercontent.com/caldav/v2/"
    },
    "carddav": {
      "serverUrl": "https://www.googleapis.com/.well-known/carddav"
    }
  },
  "llm": {
    "type": "ollama",
    "model": "qwen2.5:32b-instruct"
  },
  "mailbox": {
    "envVar": "ENCLAWED_SECRETARY_MAILBOX_EMAIL",
    "prompt": "Email address of the SECRETARY itself — the mailbox the agent signs in to (its IMAP/SMTP credentials). NOT your personal address. Recommended: a dedicated account (e.g. yourname-secretary@gmail.com) so the secretary's traffic is isolated from your personal mail"
  },
  "principal": {
    "envVar": "ENCLAWED_SECRETARY_PRINCIPAL_EMAIL",
    "prompt": "Principal email — YOUR personal address, the human authorized to administrate this secretary. The HITL approval emails will be sent here and matched against this address when you reply. Defaults to the secretary mailbox itself (self-admin install)"
  },
  "persona": {
    "displayNameEnvVar": "ENCLAWED_SECRETARY_DISPLAY_NAME",
    "systemPromptEnvVar": "ENCLAWED_SECRETARY_SYSTEM_PROMPT",
    "defaultDisplayName": "Secretary",
    "defaultSystemPrompt": ""
  },
  "service": {
    "id": "com.enclawed.secretary",
    "description": "Enclawed AI Secretary",
    "extraEnv": {
      "ENCLAWED_FIPS_REQUIRED": "0",
      "ENCLAWED_FLAVOR": "open"
    }
  },
  "labels": [{ "name": "enclawed/processed" }, { "name": "enclawed/auto-trash-eod" }],
  "docsUrl": "https://www.enclawed.com/enclawed-apps/secretary",
  "serviceReady": true
}
