# Live MCP test credentials — TEMPLATE. Copy to .env.local and fill in.
#   cp live-test.env.example .env.local      # .env.local is gitignored
# Then run:
#   set -a; source .env.local; set +a
#   npx vitest run --config vitest.live.config.mts
#
# NEVER paste real tokens into chat or commit them. .env.local stays local.

# ---- Ollama (local LLM that generates adversarial inputs / drives the agent) ----
# Install:  https://ollama.com  ->  ollama pull llama3.2  ->  ollama serve
OLLAMA_LIVE=1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---- Google Workspace OAuth (only needed for google-e2e.live.test.ts) ----
GOOGLE_LIVE=1
#
# Provide EITHER a ready access token (simplest, expires ~1h):
#   ENCLAWED_GOOGLE_OAUTH_TOKEN=ya29....
# OR a refresh-token triple (long-lived):
#   ENCLAWED_GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
#   ENCLAWED_GOOGLE_OAUTH_CLIENT_SECRET=....
#   ENCLAWED_GOOGLE_OAUTH_REFRESH_TOKEN=1//....
#
# IMPORTANT: the token MUST carry a Workspace scope that covers the tool under
# test. For the `list_labels` positive case, mint the token with at least:
#   https://www.googleapis.com/auth/gmail.readonly
# The openid/email/profile scopes alone are NOT sufficient.
ENCLAWED_GOOGLE_OAUTH_TOKEN=
