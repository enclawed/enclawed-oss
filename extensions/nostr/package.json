{
  "name": "@enclawed/nostr",
  "version": "2026.4.25",
  "description": "Enclawed Nostr channel plugin for NIP-04 encrypted DMs",
  "type": "module",
  "dependencies": {
    "nostr-tools": "^2.23.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@enclawed/plugin-sdk": "workspace:*",
    "enclawed": "workspace:*"
  },
  "peerDependencies": {
    "enclawed": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "enclawed": {
      "optional": true
    }
  },
  "enclawed": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nostr",
      "label": "Nostr",
      "selectionLabel": "Nostr (NIP-04 DMs)",
      "docsPath": "/channels/nostr",
      "docsLabel": "nostr",
      "blurb": "Decentralized protocol; encrypted DMs via NIP-04.",
      "order": 55,
      "quickstartAllowFrom": true,
      "cliAddOptions": [
        {
          "flags": "--private-key <key>",
          "description": "Nostr private key (nsec... or hex)"
        },
        {
          "flags": "--relay-urls <list>",
          "description": "Nostr relay URLs (comma-separated)"
        }
      ]
    },
    "install": {
      "npmSpec": "@enclawed/nostr",
      "defaultChoice": "npm",
      "minHostVersion": ">=0.2.0"
    },
    "compat": {
      "pluginApi": ">=0.2.0"
    },
    "build": {
      "enclawedVersion": "2026.4.25"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
