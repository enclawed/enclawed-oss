{
  "name": "@enclawed/nextcloud-talk",
  "version": "2026.4.25",
  "description": "Enclawed Nextcloud Talk channel plugin",
  "type": "module",
  "dependencies": {
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@enclawed/plugin-sdk": "workspace:*",
    "enclawed": "workspace:*"
  },
  "peerDependencies": {
    "enclawed": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "enclawed": {
      "optional": true
    }
  },
  "enclawed": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@enclawed/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=0.2.0"
    },
    "compat": {
      "pluginApi": ">=0.2.0"
    },
    "build": {
      "enclawedVersion": "2026.4.25"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
