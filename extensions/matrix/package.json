{
  "name": "@enclawed/matrix",
  "version": "2026.4.25",
  "description": "Enclawed Matrix channel plugin",
  "type": "module",
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-nodejs": "^0.5.1",
    "@matrix-org/matrix-sdk-crypto-wasm": "18.2.0",
    "fake-indexeddb": "^6.2.5",
    "jiti": "^2.6.1",
    "markdown-it": "14.1.1",
    "matrix-js-sdk": "41.4.0",
    "music-metadata": "^11.12.3",
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@enclawed/plugin-sdk": "workspace:*",
    "enclawed": "workspace:*"
  },
  "peerDependencies": {
    "enclawed": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "enclawed": {
      "optional": true
    }
  },
  "enclawed": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "setupFeatures": {
      "configPromotion": true
    },
    "channel": {
      "id": "matrix",
      "label": "Matrix",
      "selectionLabel": "Matrix (plugin)",
      "docsPath": "/channels/matrix",
      "docsLabel": "matrix",
      "blurb": "open protocol; install the plugin to enable.",
      "order": 70,
      "quickstartAllowFrom": true,
      "doctorCapabilities": {
        "dmAllowFromMode": "nestedOnly",
        "groupModel": "sender",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": true
      },
      "cliAddOptions": [
        {
          "flags": "--homeserver <url>",
          "description": "Matrix homeserver URL"
        },
        {
          "flags": "--user-id <id>",
          "description": "Matrix user ID"
        },
        {
          "flags": "--access-token <token>",
          "description": "Matrix access token"
        },
        {
          "flags": "--device-name <name>",
          "description": "Matrix device name"
        },
        {
          "flags": "--initial-sync-limit <n>",
          "description": "Matrix initial sync limit"
        }
      ],
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyMatrixAuth"
      }
    },
    "install": {
      "npmSpec": "@enclawed/matrix",
      "defaultChoice": "npm",
      "minHostVersion": ">=0.2.0",
      "allowInvalidConfigRecovery": true
    }
  }
}
