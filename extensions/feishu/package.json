{
  "name": "@enclawed/feishu",
  "version": "2026.4.25",
  "description": "Enclawed Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@enclawed/plugin-sdk": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "enclawed": "workspace:*"
  },
  "peerDependencies": {
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "enclawed": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "@larksuiteoapi/node-sdk": {
      "optional": true
    },
    "enclawed": {
      "optional": true
    }
  },
  "enclawed": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@enclawed/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=0.2.0"
    },
    "compat": {
      "pluginApi": ">=0.2.0"
    },
    "build": {
      "enclawedVersion": "2026.4.25"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
