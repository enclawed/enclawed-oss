{
  "id": "document-extract",
  "activation": {
    "onStartup": false
  },
  "enabledByDefault": true,
  "name": "Document Extraction",
  "description": "Extract text and fallback page images from local document attachments.",
  "contracts": {
    "documentExtractors": ["pdf"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowedSources": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "maxFileSizeMB": {
        "type": "number",
        "minimum": 0
      }
    }
  }
}
