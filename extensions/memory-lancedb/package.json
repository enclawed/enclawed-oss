{
  "name": "@enclawed/memory-lancedb",
  "version": "2026.4.16",
  "description": "Enclawed LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@sinclair/typebox": "0.34.49",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@enclawed/plugin-sdk": "workspace:*"
  },
  "enclawed": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@enclawed/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=0.2.0"
    },
    "compat": {
      "pluginApi": ">=0.2.0"
    },
    "build": {
      "enclawedVersion": "2026.4.16"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
